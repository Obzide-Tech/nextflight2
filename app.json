{
  "expo": {
    "name": "NextFlight Academy",
    "slug": "nextflight-academy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nextflight",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#30050E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.nextflightacademy",
      "buildNumber": "1",
      "associatedDomains": ["applinks:nextflightacademy.app"]
    },
    "android": {
      "package": "app.nextflightacademy",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#30050E"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "nextflightacademy.app", "pathPrefix": "/r" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-camera",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraBuildSettings": {
              "CLANG_CXX_LANGUAGE_STANDARD": "c++20"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
